---
import ThemeToggle from "@/components/ThemeToggle";
import { resolveBase } from "@/utils/resolve";
---

<header class="top-0 px-6 py-10 mb-4 flex items-center">
  <div class="size-9"></div>
  <div class="flex h-4 text-center items-center space-x-2 text-sm mx-auto">
    {/* Link to homepage */}
    <a
      href={resolveBase("/")}
      class="text-foreground hover:text-foreground/80"
      aria-label="home"
    >
      home
    </a>
    <span class="text-foreground/60">|</span>
    <a
      href={resolveBase("/about")}
      class="text-foreground hover:text-foreground/80"
      aria-label="about"
    >
      about
    </a>
  </div>
  {/* Theme Switcher */}
  <div class="size-9">
    <ThemeToggle client:load />
  </div>
</header>
